<footer class="disfruto-section disfruto-footer">
  <div class="disfruto-container">
    <div class="disfruto-footer__grid">
      <div>
        <div class="disfruto-footer__brand-name">{{ section.settings.brand_name }}</div>
        <p class="disfruto-footer__brand-text">{{ section.settings.brand_description }}</p>
        <div class="disfruto-footer__social">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" class="disfruto-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {% endif %}
          {% if section.settings.facebook_url != blank %}
            <a href="{{ section.settings.facebook_url }}" class="disfruto-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.tiktok_url != blank %}
            <a href="{{ section.settings.tiktok_url }}" class="disfruto-footer__social-link" target="_blank" rel="noopener" aria-label="TikTok">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13v-3.5a6.37 6.37 0 0 0-1-.05A6.28 6.28 0 0 0 3 15.57 6.29 6.29 0 0 0 9.37 22a6.28 6.28 0 0 0 6.27-6.28V9.06a8.28 8.28 0 0 0 4.84 1.56v-3.5a4.84 4.84 0 0 1-.89-.43z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'link_list' %}
          <div {{ block.shopify_attributes }}>
            <h4 class="disfruto-footer__heading">{{ block.settings.heading }}</h4>
            <ul class="disfruto-footer__links">
              {% if block.settings.menu != blank %}
                {% for link in linklists[block.settings.menu].links %}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {% endfor %}
              {% endif %}
              {% if block.settings.link_1_label != blank %}
                <li><a href="{{ block.settings.link_1_url }}">{{ block.settings.link_1_label }}</a></li>
              {% endif %}
              {% if block.settings.link_2_label != blank %}
                <li><a href="{{ block.settings.link_2_url }}">{{ block.settings.link_2_label }}</a></li>
              {% endif %}
              {% if block.settings.link_3_label != blank %}
                <li><a href="{{ block.settings.link_3_url }}">{{ block.settings.link_3_label }}</a></li>
              {% endif %}
              {% if block.settings.link_4_label != blank %}
                <li><a href="{{ block.settings.link_4_url }}">{{ block.settings.link_4_label }}</a></li>
              {% endif %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="disfruto-footer__bottom">
      <div class="disfruto-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}. Alle Rechte vorbehalten.
      </div>
      <div class="disfruto-footer__bottom-links">
        {% if section.settings.privacy_url != blank %}
          <a href="{{ section.settings.privacy_url }}">Datenschutz</a>
        {% endif %}
        {% if section.settings.terms_url != blank %}
          <a href="{{ section.settings.terms_url }}">AGB</a>
        {% endif %}
        {% if section.settings.imprint_url != blank %}
          <a href="{{ section.settings.imprint_url }}">Impressum</a>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Disfruto Footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "Disfruto"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand Description",
      "default": "Kuratierte Käse-Spezialitäten, direkt an deine Tür in Berlin geliefert."
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Datenschutz URL"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "AGB URL"
    },
    {
      "type": "url",
      "id": "imprint_url",
      "label": "Impressum URL"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "text",
          "id": "link_1_label",
          "label": "Link 1 Label"
        },
        {
          "type": "url",
          "id": "link_1_url",
          "label": "Link 1 URL"
        },
        {
          "type": "text",
          "id": "link_2_label",
          "label": "Link 2 Label"
        },
        {
          "type": "url",
          "id": "link_2_url",
          "label": "Link 2 URL"
        },
        {
          "type": "text",
          "id": "link_3_label",
          "label": "Link 3 Label"
        },
        {
          "type": "url",
          "id": "link_3_url",
          "label": "Link 3 URL"
        },
        {
          "type": "text",
          "id": "link_4_label",
          "label": "Link 4 Label"
        },
        {
          "type": "url",
          "id": "link_4_url",
          "label": "Link 4 URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Disfruto Footer",
      "blocks": [
        {
          "type": "link_list",
          "settings": {
            "heading": "Produkt",
            "link_1_label": "So funktioniert's",
            "link_2_label": "Unsere Käse",
            "link_3_label": "Preise"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "Unternehmen",
            "link_1_label": "Über uns",
            "link_2_label": "FAQ",
            "link_3_label": "Kontakt"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "Kontakt",
            "link_1_label": "hallo@disfruto.de",
            "link_2_label": "Berlin, Deutschland"
          }
        }
      ]
    }
  ]
}
{% endschema %}
