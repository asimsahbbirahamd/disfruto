            "tag": "Blauschimmel",
            "profile_milk": "Kuhmilch",
            "profile_texture": "Cremig & weich",
            "profile_intensity": 3,
            "profile_aging": "8 Wochen",
            "profile_aromas": "Würzig, mild",
            "profile_pairing": "Portwein, Birne"
          }
        },
        {
          "type": "cheese",
          "settings": {
            "name": "Grosser Husumer",
            "description": "Vollmundiger Schnittkäse mit aromatischer Reife und butterweicher Textur.",
            "tag": "Schnittkäse",
