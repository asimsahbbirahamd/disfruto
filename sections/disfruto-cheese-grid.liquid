<section class="disfruto-section disfruto-cheeses">
  <div class="disfruto-container">
    <div class="disfruto-cheeses__header">
      {% if section.settings.eyebrow != blank %}
        <span class="disfruto-cheeses__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="disfruto-cheeses__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="disfruto-cheeses__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  </div>
  <div class="disfruto-cheeses__slider-wrap">
    <div class="disfruto-container">
      <div class="disfruto-cheeses__grid">
        {% for block in section.blocks %}
          <div class="disfruto-cheese-card" {{ block.shopify_attributes }}>
            <div class="disfruto-cheese-card__image">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 500 | image_tag: loading: 'lazy' }}
              {% else %}
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#EDEDE8,#E5E5DF);">
                  <svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="30" cy="30" r="25" fill="#1E4A47" opacity="0.15"/>
                    <circle cx="22" cy="25" r="3" fill="#1E4A47" opacity="0.2"/>
                    <circle cx="35" cy="32" r="4" fill="#1E4A47" opacity="0.2"/>
                    <circle cx="28" cy="38" r="2" fill="#1E4A47" opacity="0.2"/>
                  </svg>
                </div>
              {% endif %}
              {% if block.settings.profile_milk != blank or block.settings.profile_texture != blank %}
                <div class="disfruto-cheese-card__profile">
                  <div class="disfruto-cheese-card__profile-title">Geschmacksprofil</div>
                  {% if block.settings.profile_milk != blank %}
                    <div class="disfruto-cheese-card__profile-row">
                      <span class="disfruto-cheese-card__profile-label">Milch</span>
                      <span class="disfruto-cheese-card__profile-value">{{ block.settings.profile_milk }}</span>
                    </div>
                  {% endif %}
                  {% if block.settings.profile_texture != blank %}
                    <div class="disfruto-cheese-card__profile-row">
                      <span class="disfruto-cheese-card__profile-label">Textur</span>
                      <span class="disfruto-cheese-card__profile-value">{{ block.settings.profile_texture }}</span>
                    </div>
                  {% endif %}
                  <div class="disfruto-cheese-card__profile-row">
                    <span class="disfruto-cheese-card__profile-label">Intensität</span>
                    <span class="disfruto-cheese-card__profile-value">
                      <span class="disfruto-cheese-card__profile-dots">
                        {% for i in (1..5) %}
                          <span class="disfruto-cheese-card__profile-dot{% if i <= block.settings.profile_intensity %} disfruto-cheese-card__profile-dot--active{% endif %}"></span>
                        {% endfor %}
                      </span>
                    </span>
                  </div>
                  {% if block.settings.profile_aging != blank %}
                    <div class="disfruto-cheese-card__profile-row">
                      <span class="disfruto-cheese-card__profile-label">Reifung</span>
                      <span class="disfruto-cheese-card__profile-value">{{ block.settings.profile_aging }}</span>
                    </div>
                  {% endif %}
                  {% if block.settings.profile_aromas != blank %}
                    <div class="disfruto-cheese-card__profile-row">
                      <span class="disfruto-cheese-card__profile-label">Aromen</span>
                      <span class="disfruto-cheese-card__profile-value">{{ block.settings.profile_aromas }}</span>
                    </div>
                  {% endif %}
                  {% if block.settings.profile_pairing != blank %}
                    <div class="disfruto-cheese-card__profile-row">
                      <span class="disfruto-cheese-card__profile-label">Passt zu</span>
                      <span class="disfruto-cheese-card__profile-value">{{ block.settings.profile_pairing }}</span>
                    </div>
                  {% endif %}
                </div>
              {% endif %}
            </div>
            <div class="disfruto-cheese-card__body">
              <h3 class="disfruto-cheese-card__name">{{ block.settings.name }}</h3>
              <p class="disfruto-cheese-card__desc">{{ block.settings.description }}</p>
              {% if block.settings.tag != blank %}
                <span class="disfruto-cheese-card__tag">{{ block.settings.tag }}</span>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Disfruto Cheese Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Unsere Auswahl"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Entdecke unsere Käse-Vielfalt"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Handverlesene Sorten von den besten Käsemachern Europas"
    }
  ],
  "blocks": [
    {
      "type": "cheese",
      "name": "Cheese",
