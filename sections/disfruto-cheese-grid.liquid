        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Käse Name"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Beschreibung des Käses"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag (optional)"
        },
        {
          "type": "header",
          "content": "Geschmacksprofil (Hover-Overlay)"
        },
        {
          "type": "text",
          "id": "profile_milk",
          "label": "Milchart",
          "default": "Kuhmilch"
        },
        {
          "type": "text",
          "id": "profile_texture",
          "label": "Textur",
          "default": "Cremig"
        },
        {
          "type": "range",
          "id": "profile_intensity",
          "label": "Intensität",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 3
        },
        {
          "type": "text",
          "id": "profile_aging",
          "label": "Reifung",
          "default": "8 Wochen"
        },
        {
          "type": "text",
          "id": "profile_aromas",
          "label": "Aromen",
          "default": "Nussig, mild"
        },
        {
          "type": "text",
          "id": "profile_pairing",
          "label": "Passt zu",
