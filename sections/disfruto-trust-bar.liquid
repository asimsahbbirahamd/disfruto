<section class="disfruto-section disfruto-trust">
  <div class="disfruto-container">
    <div class="disfruto-trust__grid">
      {% for block in section.blocks %}
        <div class="disfruto-trust__item" {{ block.shopify_attributes }}>
          <div class="disfruto-trust__icon">
            {% case block.settings.icon %}
              {% when 'delivery' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {% when 'flexible' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {% when 'pause' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="10" y1="15" x2="10" y2="9"/><line x1="14" y1="15" x2="14" y2="9"/></svg>
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            {% endcase %}
          </div>
          <div>
            <div class="disfruto-trust__label">{{ block.settings.label }}</div>
            {% if block.settings.sublabel != blank %}
              <div class="disfruto-trust__sublabel">{{ block.settings.sublabel }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Disfruto Trust Bar",
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "delivery", "label": "Delivery" },
            { "value": "flexible", "label": "Flexible" },
            { "value": "pause", "label": "Pause" },
            { "value": "check", "label": "Check" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Trust Signal"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Sublabel"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Disfruto Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "delivery",
            "label": "Kostenfrei geliefert",
            "sublabel": "In ganz Berlin"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "flexible",
            "label": "Flexibel planbar",
            "sublabel": "Alle 2 oder 4 Wochen"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "pause",
            "label": "Jederzeit pausierbar",
            "sublabel": "Kein Vertrag, keine Bindung"
          }
        }
      ]
    }
  ]
}
{% endschema %}
