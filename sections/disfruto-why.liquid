<section class="disfruto-section disfruto-why">
  <div class="disfruto-container">
    <div class="disfruto-why__layout">
      <div class="disfruto-why__manifesto">
        {% if section.settings.eyebrow != blank %}
          <span class="disfruto-why__eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        <h2 class="disfruto-why__title">{{ section.settings.heading }}</h2>
        {% if section.settings.statement != blank %}
          <p class="disfruto-why__statement">{{ section.settings.statement }}</p>
        {% endif %}
        {% if section.settings.cta_label != blank %}
          <a href="{{ section.settings.cta_link }}" class="disfruto-btn disfruto-btn--outline">
            {{ section.settings.cta_label }}
          </a>
        {% endif %}
      </div>
      <div class="disfruto-why__benefits">
        {% for block in section.blocks %}
          <div class="disfruto-why__item" {{ block.shopify_attributes }}>
            <span class="disfruto-why__number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <div class="disfruto-why__item-content">
              <h3 class="disfruto-why__item-title">{{ block.settings.title }}</h3>
              <p class="disfruto-why__item-text">{{ block.settings.description }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var items = document.querySelectorAll('.disfruto-why__item, .disfruto-why__manifesto');
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
      items.forEach(function(item) { observer.observe(item); });
    } else {
      items.forEach(function(item) { item.classList.add('is-visible'); });
    }
  });
</script>

{% schema %}
{
  "name": "Disfruto Why Us",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Warum Disfruto"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Käse, der Geschichten erzählt"
    },
    {
      "type": "textarea",
      "id": "statement",
      "label": "Manifesto Statement",
      "default": "Wir glauben, dass großartiger Käse mehr ist als ein Lebensmittel. Er ist Ausdruck von Handwerk, Terroir und der Leidenschaft der Menschen, die ihn herstellen. Disfruto bringt diese Geschichten direkt zu dir nach Hause — kuratiert, authentisch und immer aus den besten Käsereien Europas."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "Unsere Geschichte entdecken"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Benefit description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Disfruto Why Us",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Transparente Herkunft",
            "description": "Jeder Käse kommt mit seiner Geschichte: Wer ihn gemacht hat, woher die Milch stammt und wie er gereift wurde. Keine anonyme Massenware."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Meisterliches Handwerk",
            "description": "Wir arbeiten ausschließlich mit Käsereien, die ihr Handwerk über Generationen perfektioniert haben — von den Alpen bis an die Nordsee."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Kuratierte Vielfalt",
            "description": "Jede Box ist eine Komposition: Sorgfältig aufeinander abgestimmt in Geschmack, Textur und Reife — damit jeder Bissen überrascht."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Berlin, flexibel geliefert",
            "description": "Donnerstag bis Sonntag, alle 2 oder 4 Wochen — kostenlos an deine Tür. Pausiere oder kündige jederzeit, ganz ohne Bindung."
          }
        }
      ]
    }
  ]
}
{% endschema %}
