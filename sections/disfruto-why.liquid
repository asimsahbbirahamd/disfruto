<section class="disfruto-section disfruto-why">
  <div class="disfruto-container">
    <div class="disfruto-why__header">
      {% if section.settings.eyebrow != blank %}
        <span class="disfruto-why__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="disfruto-why__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="disfruto-why__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="disfruto-why__grid">
      {% for block in section.blocks %}
        <div class="disfruto-why__item" {{ block.shopify_attributes }}>
          <div class="disfruto-why__icon">
            {% case block.settings.icon %}
              {% when 'eye' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              {% when 'hand' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {% when 'layers' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
              {% when 'truck' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            {% endcase %}
          </div>
          <h3 class="disfruto-why__item-title">{{ block.settings.title }}</h3>
          <p class="disfruto-why__item-text">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Disfruto Why Us",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Unsere Werte"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Warum Disfruto"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Qualität, Handwerk und Genuss — das sind unsere Versprechen"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "eye", "label": "Eye (Transparency)" },
            { "value": "hand", "label": "Star (Craftsmanship)" },
            { "value": "layers", "label": "Layers (Variety)" },
            { "value": "truck", "label": "Truck (Delivery)" },
            { "value": "check", "label": "Check" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Benefit description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Disfruto Why Us",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "eye",
            "title": "Verstehen, was du isst",
            "description": "Wir zeigen dir genau, woher dein Käse kommt, wer ihn herstellt und wie er gereift wird."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "hand",
            "title": "Handwerkliche Kunst",
            "description": "Jeder Käse wird von erfahrenen Käsemachern nach traditionellen Methoden hergestellt."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "layers",
            "title": "Vielfalt und Balance",
            "description": "Unsere Boxen bieten eine perfekt abgestimmte Auswahl verschiedener Geschmacksrichtungen."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "truck",
            "title": "Flexible Lieferung",
            "description": "Wähle deinen Liefertag und passe dein Abo jederzeit an — ganz ohne Bindung."
          }
        }
      ]
    }
  ]
}
{% endschema %}
