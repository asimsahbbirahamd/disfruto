<section class="disfruto-section disfruto-hero">
  <div class="disfruto-container">
    <div class="disfruto-hero__inner">
      <div class="disfruto-hero__content">
        {% if section.settings.badge_text != blank %}
          <span class="disfruto-hero__badge">{{ section.settings.badge_text }}</span>
        {% endif %}
        <h1 class="disfruto-hero__title">{{ section.settings.heading }}</h1>
        <p class="disfruto-hero__subtitle">{{ section.settings.subheading }}</p>
        <div class="disfruto-hero__actions">
          {% if section.settings.button_label != blank %}
            <a href="{{ section.settings.button_link }}" class="disfruto-btn disfruto-btn--primary">
              {{ section.settings.button_label }}
            </a>
          {% endif %}
          {% if section.settings.button_label_2 != blank %}
            <a href="{{ section.settings.button_link_2 }}" class="disfruto-btn disfruto-btn--secondary">
              {{ section.settings.button_label_2 }}
            </a>
          {% endif %}
        </div>
      </div>
      <div class="disfruto-hero__visual">
        <div class="disfruto-hero__image-wrapper">
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'eager', class: '' }}
          {% else %}
            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#E8E0D4,#D4C8B8);min-height:500px;">
              <svg width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="60" cy="60" r="50" fill="#C4A882" opacity="0.3"/>
                <circle cx="60" cy="60" r="30" fill="#C4A882" opacity="0.5"/>
                <text x="60" y="65" text-anchor="middle" fill="#8B6F47" font-family="Georgia" font-size="14">Käse Box</text>
              </svg>
            </div>
          {% endif %}
        </div>
        <div class="disfruto-hero__float-badge">
          <div class="disfruto-hero__float-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <div class="disfruto-hero__float-text">{{ section.settings.float_badge_text }}</div>
            <div class="disfruto-hero__float-sub">{{ section.settings.float_badge_subtext }}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Disfruto Hero",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Neu in Berlin"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dein 1. Käse Genuss Set Gratis"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Kuratierte Käse-Spezialitäten direkt an deine Tür in Berlin geliefert. Handverlesen von den besten Käsemachern."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary Button Label",
      "default": "Jetzt ausprobieren"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Button Label",
      "default": "Mehr erfahren"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "float_badge_text",
      "label": "Float Badge Text",
      "default": "Kostenlose Lieferung"
    },
    {
      "type": "text",
      "id": "float_badge_subtext",
      "label": "Float Badge Subtext",
      "default": "In ganz Berlin"
    }
  ],
  "presets": [
    {
      "name": "Disfruto Hero"
    }
  ]
}
{% endschema %}
