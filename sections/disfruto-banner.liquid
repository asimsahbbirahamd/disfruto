<section class="disfruto-section" style="padding:0;">
  <div style="width:100%;height:{{ section.settings.height }}px;overflow:hidden;position:relative;">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1920 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
    {% else %}
      <div style="width:100%;height:100%;background:linear-gradient(135deg,#E8E0D4,#D4C8B8);"></div>
    {% endif %}
    <div style="position:absolute;inset:0;background:{{ section.settings.overlay_gradient }};display:flex;align-items:center;">
      <div class="disfruto-container" style="width:100%;">
        <div style="max-width:480px;">
          <h2 style="font-family:var(--disfruto-font-heading);font-size:36px;font-weight:600;color:#fff;margin:0 0 16px;line-height:1.2;">{{ section.settings.heading }}</h2>
          <p style="font-size:17px;color:rgba(255,255,255,0.8);margin:0 0 28px;line-height:1.6;">{{ section.settings.text }}</p>
          {% if section.settings.button_label != blank %}
            <a href="{{ section.settings.button_link }}" class="disfruto-btn disfruto-btn--warm">{{ section.settings.button_label }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Disfruto Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "height",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Banner Height",
      "default": 360
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Starte deine Käse-Reise"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text",
      "default": "Entdecke jeden Monat neue Geschmackswelten mit unserer kuratierten Käse-Box."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Jetzt abonnieren"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "overlay_gradient",
      "label": "Overlay Gradient CSS",
      "default": "linear-gradient(to right,rgba(44,44,44,0.7) 0%,rgba(44,44,44,0.3) 50%,transparent 100%)"
    }
  ],
  "presets": [
    {
      "name": "Disfruto Banner"
    }
  ]
}
{% endschema %}
