<section class="disfruto-section disfruto-how-it-works">
  <div class="disfruto-container">
    <div class="disfruto-how-it-works__header">
      {% if section.settings.eyebrow != blank %}
        <span class="disfruto-how-it-works__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="disfruto-how-it-works__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="disfruto-how-it-works__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="disfruto-how-it-works__steps">
      {% for block in section.blocks %}
        <div class="disfruto-how-it-works__step" {{ block.shopify_attributes }}>
          <div class="disfruto-how-it-works__step-number">{{ forloop.index }}</div>
          <h3 class="disfruto-how-it-works__step-title">{{ block.settings.title }}</h3>
          <p class="disfruto-how-it-works__step-text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
    {% if section.settings.cta_label != blank %}
      <div class="disfruto-how-it-works__cta">
        <a href="{{ section.settings.cta_link }}" class="disfruto-btn disfruto-btn--warm">{{ section.settings.cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Disfruto How It Works",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "So einfach geht's"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "So funktioniert's"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "In nur drei Schritten zu deinem persönlichen Käse-Erlebnis — kuratiert, geliefert, genossen."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "Genuss Set wählen"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Schritt"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Step Description",
          "default": "Beschreibung"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Disfruto How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Genuss Set wählen",
            "text": "Wähle zwischen unserem Klassik oder Premium Set — je nach deinem Geschmack und Appetit. Beide Sets werden von unseren Käse-Experten sorgfältig zusammengestellt."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Lieferrhythmus bestimmen",
            "text": "Entscheide, ob du alle 2 oder alle 4 Wochen beliefert werden möchtest. Wähle deinen bevorzugten Liefertag (Do–So). Flexibel änderbar, jederzeit pausierbar."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Genießen & entdecken",
            "text": "Deine kuratierte Käse-Box kommt frisch an deine Tür in Berlin. Mit Tasting Notes, Herkunftsgeschichten und Genuss-Tipps zu jeder Sorte."
          }
        }
      ]
    }
  ]
}
{% endschema %}
