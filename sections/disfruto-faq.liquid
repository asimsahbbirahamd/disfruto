<section id="faq" class="disfruto-section disfruto-faq">
  <div class="disfruto-container">
    <div class="disfruto-faq__header">
      {% if section.settings.eyebrow != blank %}
        <span class="disfruto-faq__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="disfruto-faq__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="disfruto-faq__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="disfruto-faq__list">
      {% for block in section.blocks %}
        <details class="disfruto-faq__item" {{ block.shopify_attributes }}>
          <summary class="disfruto-faq__question">
            <span class="disfruto-faq__question-text">{{ block.settings.question }}</span>
            <span class="disfruto-faq__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </summary>
          <div class="disfruto-faq__answer">
            {{ block.settings.answer }}
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Disfruto FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Häufige Fragen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Alles, was du wissen musst"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Hier findest du Antworten auf die häufigsten Fragen rund um Disfruto"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Frage"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Antwort</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Disfruto FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "Was ist Disfruto?",
            "answer": "<p>Disfruto ist ein Käse-Abonnement, das dir kuratierte Käse-Spezialitäten direkt an die Tür in Berlin liefert. Jede Box enthält handverlesene Sorten von den besten Käsemachern Europas.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Wie oft wird geliefert?",
            "answer": "<p>Du kannst zwischen zwei Lieferintervallen wählen: alle 2 Wochen oder alle 4 Wochen. Dein Abo kannst du jederzeit anpassen.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "An welchen Tagen wird geliefert?",
            "answer": "<p>Wir liefern donnerstags bis sonntags in ganz Berlin. Du wählst bei der Bestellung deinen bevorzugten Liefertag.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Kann ich mein Abo pausieren oder kündigen?",
            "answer": "<p>Ja, du kannst dein Abonnement jederzeit pausieren, überspringen oder kündigen — ganz ohne Bindung oder versteckte Kosten.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Liefert ihr auch außerhalb von Berlin?",
            "answer": "<p>Aktuell liefern wir nur innerhalb Berlins, um die Frische und Qualität unserer Käse-Spezialitäten zu garantieren. Eine Expansion ist geplant.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Ist die Lieferung kostenlos?",
            "answer": "<p>Ja, die Lieferung ist für alle Abonnenten in Berlin komplett kostenlos — egal ob du alle 2 oder alle 4 Wochen bestellst.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
