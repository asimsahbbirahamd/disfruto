<div class="disfruto-faq-hero">
  <div class="disfruto-faq-hero__inner">
    <h1 class="disfruto-faq-hero__title">{{ section.settings.heading }}</h1>
    {% if section.settings.subheading != blank %}
      <p class="disfruto-faq-hero__subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>
</div>

<section class="disfruto-faq-page">
  <div class="disfruto-faq-page__container">
    {% assign current_category = '' %}
    {% for block in section.blocks %}
      {% if block.type == 'category' %}
        {% if current_category != '' %}
          </div>
        {% endif %}
        <div class="disfruto-faq-page__group">
          <h2 class="disfruto-faq-page__category">{{ block.settings.title }}</h2>
        {% assign current_category = block.settings.title %}
      {% elsif block.type == 'faq' %}
        {% if current_category == '' %}
          <div class="disfruto-faq-page__group">
          {% assign current_category = 'default' %}
        {% endif %}
        <details class="disfruto-faq-page__item" {{ block.shopify_attributes }}>
          <summary class="disfruto-faq-page__question">
            <span class="disfruto-faq-page__question-text">{{ block.settings.question }}</span>
            <span class="disfruto-faq-page__chevron">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </summary>
          <div class="disfruto-faq-page__answer">
            {{ block.settings.answer }}
          </div>
        </details>
      {% endif %}
    {% endfor %}
    {% if current_category != '' %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Disfruto FAQ Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Hero Heading",
      "default": "Häufige Fragen"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Hero Subheading",
      "default": "Alles, was du über disfruto wissen möchtest."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Heading",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Kategorie"
        }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Frage"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Antwort</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Disfruto FAQ Page"
    }
  ]
}
{% endschema %}