<section class="disfruto-km-hero">
  {% if section.settings.hero_image != blank %}
    {{ section.settings.hero_image | image_url: width: 1600 | image_tag: class: 'disfruto-km-hero__img', loading: 'eager', alt: section.settings.name }}
  {% else %}
    <img src="https://images.unsplash.com/photo-1500595046743-cd271d694d30?w=1600&h=500&fit=crop&q=80" alt="Weidelandschaft" class="disfruto-km-hero__img">
  {% endif %}
</section>

<section class="disfruto-section disfruto-km">
  <div class="disfruto-container disfruto-km__container">
    <span class="disfruto-km__eyebrow">{{ section.settings.eyebrow }}</span>
    <h1 class="disfruto-km__name">{{ section.settings.name }}</h1>
    <p class="disfruto-km__subtitle">{{ section.settings.subtitle }}</p>

    <div class="disfruto-km__portrait">
      {% if section.settings.portrait != blank %}
        {{ section.settings.portrait | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.name }}
      {% else %}
        <img src="https://images.unsplash.com/photo-1595475207225-428b62bda831?w=800&h=520&fit=crop&q=80" alt="{{ section.settings.name }}" loading="lazy">
      {% endif %}
    </div>

    <div class="disfruto-km__body">
      {% for block in section.blocks %}
        {% if block.type == 'text_column' %}
          <div class="disfruto-km__col" {{ block.shopify_attributes }}>
            <p>{{ block.settings.text }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.quote != blank %}
      <blockquote class="disfruto-km__quote">
        <p>{{ section.settings.quote }}</p>
      </blockquote>
    {% endif %}
  </div>
</section>

{% if section.settings.cta_label != blank %}
  <section class="disfruto-section disfruto-km-cta">
    <div class="disfruto-container">
      <h2 class="disfruto-km-cta__title">{{ section.settings.cta_heading }}</h2>
      <a href="{{ section.settings.cta_link }}" class="disfruto-km-cta__btn">{{ section.settings.cta_label }}</a>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Disfruto Käsemacher",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image (full-width landscape)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Käsemacher der Woche"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Maker Name",
      "default": "Backensholz"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Rohmilchkäse aus Schleswig-Holstein"
    },
    {
      "type": "image_picker",
      "id": "portrait",
      "label": "Portrait / Feature Image"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote / Summary",
      "default": "Backensholz steht für eine Arbeitsweise, die Verantwortung nicht auslagert. Vom Gras bis zum gereiften Käse bleibt alles in einer Hand. Das Ergebnis ist ein Käse mit Tiefe, Struktur und Herkunft."
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "Neugierig?"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "PROBIERE UNSER GENUSS SET"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link",
      "default": "/collections/all"
    }
  ],
  "blocks": [
    {
      "type": "text_column",
      "name": "Text Column",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Paragraph Text"
        }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Disfruto Käsemacher"
    }
  ]
}
{% endschema %}
