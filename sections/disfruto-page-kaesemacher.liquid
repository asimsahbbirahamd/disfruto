<section class="disfruto-section disfruto-makers-page">
  <div class="disfruto-container">
    <div class="disfruto-makers-page__header">
      {% if section.settings.eyebrow != blank %}
        <span class="disfruto-makers-page__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="disfruto-makers-page__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="disfruto-makers-page__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="disfruto-makers-page__grid">
      {% for block in section.blocks %}
        <div class="disfruto-makers-page__card" {{ block.shopify_attributes }}>
          <div class="disfruto-makers-page__card-image">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {% else %}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#F0EBE1,#E8E0D4);min-height:280px;">
                <svg width="60" height="60" viewBox="0 0 80 80" fill="none"><circle cx="40" cy="32" r="16" fill="#1E4A47" opacity="0.15"/><path d="M20 65c0-11 9-20 20-20s20 9 20 20" fill="#1E4A47" opacity="0.1"/></svg>
              </div>
            {% endif %}
          </div>
          <div class="disfruto-makers-page__card-content">
            <h3 class="disfruto-makers-page__card-name">{{ block.settings.name }}</h3>
            <span class="disfruto-makers-page__card-region">{{ block.settings.region }}</span>
            <p class="disfruto-makers-page__card-text">{{ block.settings.description }}</p>
            <span class="disfruto-makers-page__card-specialty">{{ block.settings.specialty }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Disfruto Käsemacher Page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Unsere Partner"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Käsemacher mit Leidenschaft"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Wir arbeiten mit den besten handwerklichen Käsereien Europas zusammen. Jeder Käsemacher steht für Tradition, Qualität und Hingabe."
    }
  ],
  "blocks": [
    {
      "type": "maker",
      "name": "Käsemacher",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Käsemacher Name"
        },
        {
          "type": "text",
          "id": "region",
          "label": "Region",
          "default": "Region, Land"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Beschreibung des Käsemachers und seiner Philosophie."
        },
        {
          "type": "text",
          "id": "specialty",
          "label": "Specialty",
          "default": "Spezialität: Bergkäse"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Disfruto Käsemacher Page",
      "blocks": [
        {
          "type": "maker",
          "settings": {
            "name": "Familie Schönberg",
            "region": "Nordfriesland, Deutschland",
            "description": "Seit drei Generationen stellt Familie Schönberg auf ihrer kleinen Hofkäserei in Nordfriesland handwerklichen Käse her. Ihre Kühe grasen auf den salzigen Weiden der Nordseeküste.",
            "specialty": "Spezialität: Nordfriesischer Deichkäse"
          }
        },
        {
          "type": "maker",
          "settings": {
            "name": "Pierre & Claire Dubois",
            "region": "Auvergne, Frankreich",
            "description": "In den vulkanischen Highlands der Auvergne reifen die Käse von Pierre und Claire in natürlichen Höhlen. Ihre Methoden sind seit 150 Jahren unverändert.",
            "specialty": "Spezialität: Höhlen-gereifter Blauschimmel"
          }
        },
        {
          "type": "maker",
          "settings": {
            "name": "Marco Benedetti",
            "region": "Piemont, Italien",
            "description": "Marco Benedetti pflegt die piemontesische Käsetradition mit Milch von seinen eigenen Ziegen. Jeder Laib wird von Hand geformt und mindestens 6 Monate gereift.",
            "specialty": "Spezialität: Piemonteser Ziegenkäse"
          }
        }
      ]
    }
  ]
}
{% endschema %}
