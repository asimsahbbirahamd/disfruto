<section class="disfruto-section disfruto-newsletter">
  <div class="disfruto-container">
    <div class="disfruto-newsletter__inner">
      <div class="disfruto-newsletter__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <h2 class="disfruto-newsletter__title">{{ section.settings.heading }}</h2>
      <p class="disfruto-newsletter__text">{{ section.settings.text }}</p>
      {% form 'customer', class: 'disfruto-newsletter__form' %}
        <input
          type="email"
          name="contact[email]"
          class="disfruto-newsletter__input"
          placeholder="{{ section.settings.placeholder }}"
          required
          autocomplete="email"
        >
        <button type="submit" class="disfruto-btn disfruto-btn--primary">
          {{ section.settings.button_label }}
        </button>
      {% endform %}
      {% if section.settings.privacy_text != blank %}
        <p class="disfruto-newsletter__privacy">{{ section.settings.privacy_text }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Disfruto Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Neue Sorten & Genuss-Tipps direkt ins Postfach"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text",
      "default": "Melde dich an und erfahre als Erstes von neuen Käsesorten, exklusiven Angeboten und Geschichten unserer Käsemacher."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "Deine E-Mail-Adresse"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Anmelden"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy Text",
      "default": "Kein Spam, jederzeit abbestellbar. Datenschutz ist uns wichtig."
    }
  ],
  "presets": [
    {
      "name": "Disfruto Newsletter"
    }
  ]
}
{% endschema %}
