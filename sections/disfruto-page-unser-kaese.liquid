<section class="disfruto-section disfruto-unser-kaese">
  <div class="disfruto-container">
    <div class="disfruto-unser-kaese__header">
      {% if section.settings.eyebrow != blank %}
        <span class="disfruto-unser-kaese__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="disfruto-unser-kaese__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="disfruto-unser-kaese__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="disfruto-unser-kaese__features">
      {% for block in section.blocks %}
        <div class="disfruto-unser-kaese__feature" {{ block.shopify_attributes }}>
          <div class="disfruto-unser-kaese__feature-icon">
            {% if block.settings.icon == 'hand' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 13"/></svg>
            {% elsif block.settings.icon == 'leaf' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.8 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            {% elsif block.settings.icon == 'truck' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5v8h1"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {% endif %}
          </div>
          <h3 class="disfruto-unser-kaese__feature-title">{{ block.settings.title }}</h3>
          <p class="disfruto-unser-kaese__feature-text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
    {% if section.settings.cta_label != blank %}
      <div class="disfruto-unser-kaese__cta">
        <a href="{{ section.settings.cta_link }}" class="disfruto-btn disfruto-btn--warm">{{ section.settings.cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Disfruto Unser Käse Intro",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Unsere Philosophie"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Käse mit Charakter"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Wir kuratieren die besten handwerklich hergestellten Käsesorten Europas — direkt von kleinen Hofkäsereien zu dir nach Hause in Berlin."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "Genuss Set wählen"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "hand", "label": "Handwerk" },
            { "value": "leaf", "label": "Natürlich" },
            { "value": "truck", "label": "Lieferung" },
            { "value": "star", "label": "Qualität" }
          ],
          "default": "star"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Beschreibung"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Disfruto Unser Käse Intro",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "hand",
            "title": "Handwerklich hergestellt",
            "text": "Jeder Käse wird von erfahrenen Käsemachern in Handarbeit produziert — keine industrielle Massenware, sondern echtes Handwerk mit Tradition."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "leaf",
            "title": "Natürlich & nachhaltig",
            "text": "Unsere Partner setzen auf natürliche Zutaten, artgerechte Tierhaltung und nachhaltige Produktionsmethoden. Guter Käse braucht gute Milch."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "truck",
            "title": "Frisch geliefert",
            "text": "Von der Käserei direkt an deine Tür in Berlin — gekühlt und frisch, donnerstags bis sonntags. Kostenlos für alle Abonnenten."
          }
        }
      ]
    }
  ]
}
{% endschema %}
